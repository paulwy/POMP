# 数据库配置
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sksfems
REDIS_URL=redis://localhost:6379

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=86400

# 服务器配置
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# AI服务配置
# Together AI - 文生图服务 (免费额度可用)
TOGETHER_API_KEY=your-together-api-key-here
TOGETHER_API_URL=https://api.together.xyz

# Hugging Face - 备用文生图服务
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_API_URL=https://api-inference.huggingface.co

# AI模型配置
# Together AI推荐模型: black-forest-labs/FLUX.1-schnell-Free
AI_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_QUALITY=standard

# 其他AI功能配置
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2
